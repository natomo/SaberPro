__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# Jupyter
.ipynb_checkpoints/
notebooks/**/*.html

# Entornos
.env
.env.local

# Sistema operativo
.DS_Store
Thumbs.db

# Reportes generados (mantener solo figuras finales versionadas manualmente)
reports/*.log
reports/tmp/

# Editor
.vscode/
.idea/

# Resultados de tests
.pytest_cache/
.coverage
htmlcov/
